# Obsidian editor state
notes/.obsidian/workspace.json
notes/.obsidian/workspace-mobile.json
result

# Per-machine hardware config, generated by nixos-generate-config at
# install time. Keeping it out of git means a github:... flake fetch
# can never clobber the real on-disk file with a stale/placeholder copy.
hosts/*/hardware-configuration.nix
